{
  // These folders are included as is
  assets
  images

  // The home page shows all the team members
  index.html = index.ori(teamData.yaml)

  // Each team member has their own page in the team area
  team/ = Tree.map(teamData.yaml, {
    key: (person) => `${ person.name }.html`
    value: person.ori
  })

  // Thumbnails are generated for each image
  thumbnails/ = Tree.map(images, (image) => Origami.image.resize(image, { width: 200 }))
}
